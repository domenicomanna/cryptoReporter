{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C#: Debug",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/server/src/Api/Api.csproj"
    },
    {
      "name": "React: Debug with Firefox",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/clientApp"
    },
    {
      "name": "React: Debug with Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/clientApp"
    }
  ]
}
